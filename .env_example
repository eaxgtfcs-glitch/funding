# Telegram bot токен @BotFather
TELEGRAM_BOT_TOKEN=token

#Id каналов или чатов где бот админ что бы слал алерты
ALERT_CHAT_IDS=-1006666
#Id каналов или чатов где бот админ что бы слал состояние по биржам
STATE_CHAT_IDS=-1006666
#Id каналов или чатов где бот админ что бы слал критически важные события(ADL\Ликвидация\Риск ликвидации)
CRITICAL_ALERT_CHAT_IDS=-1006666

# Интервалы
# Через сколько секунд обновлять фандинг по открытым позициям (дефолт 5)
FUNDING_UPDATE_INTERVAL=3
# Через сколько секунд присылать\обновлять инфу в сообщении о состоянии бирж в телеграм боте (дефолт 30)
STATE_UPDATE_INTERVAL=3
# Через сколько секунд обновлять информацию о открытых позициях (дефолт 5)
POSITION_UPDATE_INTERVAL=3
# Через сколько секунд обновлять информацию о балансе маржи (дефолт 5)
MARGIN_UPDATE_INTERVAL=3
# Сколько раз писать о критических алертах в CRITICAL_ALERT_CHAT_IDS (дефолт 3)
CRITICAL_ALERT_SEND_COUNT=5
# Через сколько секунд писать о критических алертах в CRITICAL_ALERT_CHAT_IDS  (дефолт 5)
CRITICAL_ALERT_REPEAT_INTERVAL=5

