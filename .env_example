## --- Vest Markets ---
## Ethereum private key для ECDSA подписи запросов
#VEST_PRIVATE_KEY=
## API ключ (получается через POST /register, можно оставить пустым — зарегистрируется автоматически)
#VEST_API_KEY=
#
## --- WOOFi ---
## API ключ и секрет для HMAC-SHA256 авторизации
#WOOFI_API_KEY=
#WOOFI_SECRET_KEY=
#
## --- Pacifica ---
## Адрес кошелька (0x...) для read-запросов
#PACIFICA_WALLET_ADDRESS=
#
## --- Derive (Lyra Finance) ---
## Ethereum private key для session key (EIP-712 подпись)
#DERIVE_PRIVATE_KEY=
## Адрес кошелька (0x...)
#DERIVE_WALLET_ADDRESS=
#
## --- EdgeX ---
## ECDSA private key (hex) для подписи запросов
#EDGEX_PRIVATE_KEY=
## Числовой ID аккаунта
#EDGEX_ACCOUNT_ID=
#
## --- Ethereal ---
## Ethereum private key для EIP-712 подписи
#ETHEREAL_PRIVATE_KEY=
## Адрес кошелька (0x...)
#ETHEREAL_WALLET_ADDRESS=
## Имя subaccount (по умолчанию primary)
#ETHEREAL_SUBACCOUNT=primary
#
## --- Paradex ---
## StarkNet private key для авторизации и подписи ордеров
#PARADEX_STARK_PRIVATE_KEY=
## Ethereum private key для onboarding (если требуется)
#PARADEX_ETHEREUM_PRIVATE_KEY=
#
## --- Avantis ---
## Ethereum private key для подписи on-chain транзакций на Base
#AVANTIS_PRIVATE_KEY=
## Адрес кошелька (0x...)
#AVANTIS_WALLET_ADDRESS=
## RPC URL сети Base (например https://mainnet.base.org)
#AVANTIS_RPC_URL=
#
## --- Drift ---
## Solana private key в формате base58
#DRIFT_PRIVATE_KEY=
## Solana RPC endpoint (например от QuickNode или Helius)
#DRIFT_RPC_URL=