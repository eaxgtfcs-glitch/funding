# Telegram bot токен @BotFather
TELEGRAM_BOT_TOKEN=token

#Id каналов или чатов где бот админ что бы слал алерты по парам
PAIRS_ALERT_CHAT_IDS=-1006666
#Id каналов или чатов где бот админ что бы слал алерты по позициям
ALERT_CHAT_IDS=-1006666
#Id каналов или чатов где бот админ что бы слал состояние по биржам
STATE_CHAT_IDS=-1006666
#Id каналов или чатов где бот админ что бы слал критически важные события(ADL\Ликвидация\Риск ликвидации)
CRITICAL_ALERT_CHAT_IDS=-1006666

# Интервалы
# Через сколько секунд присылать\обновлять инфу в сообщении о состоянии бирж в телеграм боте (дефолт 30)
STATE_UPDATE_INTERVAL=10
# Через сколько секунд обновлять информацию о открытых позициях (дефолт 5)
POSITION_UPDATE_INTERVAL=3
# Через сколько секунд обновлять информацию о балансе маржи (дефолт 5)
MARGIN_UPDATE_INTERVAL=5
# Сколько раз писать о критических алертах в CRITICAL_ALERT_CHAT_IDS (дефолт 3)
CRITICAL_ALERT_SEND_COUNT=3
# Через сколько секунд повторять писать о критических алертах в CRITICAL_ALERT_CHAT_IDS  (дефолт 5)
CRITICAL_ALERT_REPEAT_INTERVAL=2

# Часовой пояс для временных меток в уведомлениях. Принимает любое IANA-имя (например Europe/Moscow, America/New_York)
NOTIFY_TIMEZONE=UTC

# Режим только для чтения: true — автозакрытие контрпозиций отключено, работают только алерты (дефолт false)
READ_ONLY_MODE=true
# Задержка перед первой проверкой структур после старта, секунды (дефолт 10)
STRUCTURES_INIT_DELAY=10

#Ключи (можно read-only)
BYBIT_API_KEY=xxx
BYBIT_API_SECRET=xxx
BINANCE_API_KEY=xxx
BINANCE_API_SECRET=xxx